{
  "rules": [
    {
      "rule_id": "js_eval_injection",
      "category": "security",
      "severity": "critical",
      "languages": ["js", "jsx", "ts", "tsx", "vue", "svelte"],
      "runtime": "universal",
      "required_tokens": ["\\beval\\("],
      "line_snippet": "const result = eval(getQueryParam('q'));",
      "language_snippets": {
        "js": "const result = eval(getQueryParam('q'));",
        "jsx": "const result = eval(getQueryParam('q'));",
        "ts": "const result: unknown = eval(getQueryParam('q'));",
        "tsx": "const result: unknown = eval(getQueryParam('q'));",
        "vue": "const result = eval(getQueryParam('q'));",
        "svelte": "const result = eval(getQueryParam('q'));"
      },
      "summary": "Unsanitized eval usage may lead to arbitrary code execution."
    },
    {
      "rule_id": "frontend_innerhtml_xss",
      "category": "security",
      "severity": "high",
      "languages": ["js", "jsx", "ts", "tsx", "vue", "svelte"],
      "runtime": "browser",
      "required_tokens": ["\\.innerHTML\\b"],
      "line_snippet": "element.innerHTML = getUntrustedHtml();",
      "language_snippets": {
        "js": "element.innerHTML = getUntrustedHtml();",
        "ts": "(element as HTMLElement).innerHTML = getUntrustedHtml();",
        "jsx": "containerRef.current.innerHTML = getUntrustedHtml();",
        "tsx": "containerRef.current!.innerHTML = getUntrustedHtml();",
        "vue": "containerRef.value.innerHTML = getUntrustedHtml();",
        "svelte": "containerEl.innerHTML = getUntrustedHtml();"
      },
      "summary": "Direct HTML assignment from untrusted input can cause XSS."
    },
    {
      "rule_id": "react_useeffect_missing_dep",
      "category": "correctness",
      "severity": "high",
      "languages": ["js", "jsx", "ts", "tsx"],
      "runtime": "browser",
      "required_tokens": ["\\buseEffect\\("],
      "line_snippet": "useEffect(() => { fetchData(query); }, []);",
      "language_snippets": {
        "js": "useEffect(() => { fetchData(query); }, []);",
        "ts": "useEffect(() => { fetchData(query); }, []);",
        "jsx": "useEffect(() => { fetchData(props.query); }, []);",
        "tsx": "useEffect(() => { fetchData(props.query); }, []);"
      },
      "summary": "useEffect dependency list is incomplete and can cause stale data bugs."
    },
    {
      "rule_id": "frontend_n_plus_one_api",
      "category": "performance",
      "severity": "medium",
      "languages": ["js", "jsx", "ts", "tsx", "vue", "svelte"],
      "runtime": "universal",
      "required_tokens": ["\\bfor\\s*\\(", "\\.then\\("],
      "line_snippet": "let chain = Promise.resolve(); for (const id of ids) { chain = chain.then(() => api.get('/items/' + id)); }",
      "language_snippets": {
        "js": "let chain = Promise.resolve(); for (const id of ids) { chain = chain.then(() => api.get('/items/' + id)); }",
        "ts": "let chain = Promise.resolve(); for (const id of ids) { chain = chain.then(() => api.get('/items/' + id)); }",
        "jsx": "let chain = Promise.resolve(); for (const id of ids) { chain = chain.then(() => api.get('/items/' + id)); }",
        "tsx": "let chain = Promise.resolve(); for (const id of ids) { chain = chain.then(() => api.get('/items/' + id)); }",
        "vue": "let chain = Promise.resolve(); for (const id of ids) { chain = chain.then(() => axios.get('/items/' + id)); }",
        "svelte": "let chain = Promise.resolve(); for (const id of ids) { chain = chain.then(() => fetch('/items/' + id)); }"
      },
      "summary": "Sequential API calls in loop can cause major latency regressions."
    },
    {
      "rule_id": "b2b2c_idor_hint",
      "category": "security",
      "severity": "high",
      "languages": ["js", "ts", "jsx", "tsx", "vue", "svelte"],
      "runtime": "universal",
      "required_tokens": ["\\.then\\("],
      "line_snippet": "fetch('/api/items/' + params.id).then((r) => r.json());",
      "language_snippets": {
        "js": "fetch('/api/items/' + params.id).then((r) => r.json());",
        "ts": "fetch('/api/items/' + params.id).then((r) => r.json());",
        "jsx": "fetch('/api/items/' + useParams().id).then((r) => r.json());",
        "tsx": "fetch('/api/items/' + useParams().id).then((r) => r.json());",
        "vue": "axios.get('/api/items/' + useRoute().params.id).then((r) => r.data);",
        "svelte": "fetch('/api/items/' + $page.params.id).then((r) => r.json());"
      },
      "summary": "Direct object access without tenant or ownership validation may cause IDOR."
    }
  ]
}
