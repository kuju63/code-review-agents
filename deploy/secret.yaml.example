# code-review-agent Secret テンプレート
#
# 使い方:
#   1. このファイルをコピーして secret.yaml を作成（.gitignore 対象）
#   2. 各値を base64 エンコードして記入:
#        echo -n "ghp_xxxx" | base64
#   3. Pod と一緒に適用:
#        podman kube play deploy/secret.yaml deploy/pod.yaml deploy/service.yaml
#
# NOTE: secret.yaml は .gitignore に登録済み。実際の値をコミットしないこと。
apiVersion: v1
kind: Secret
metadata:
  name: code-review-agent
type: Opaque
data:
  # GITHUB_TOKEN: GitHub Personal Access Token (read:org, repo スコープ)
  # echo -n "ghp_xxxx" | base64
  github-token: REPLACE_WITH_BASE64_ENCODED_TOKEN
